//Multiple stage block inside stages block

pipeline{
    agent any
    stages{
        stage('clean'){
            steps{
                echo "mvn clean"
            }
        }
        stage('validate'){
            steps{
                echo "mvn validate"
            }
        }
        stage('compile'){
            steps{
                echo "mvn compile"
            }
        }
        stage('package'){
            steps{
                echo "mvn package"
            }           
        }
    }
}

